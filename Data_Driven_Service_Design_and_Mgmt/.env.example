# ── API Keys ──────────────────────────────────────────────────────────────────
# Copy this file to .env and fill in ONE of the options below.
# The app uses Groq by default (free tier, fast).

# Option A — Groq (recommended, free at console.groq.com)
GROQ_API_KEY=your_groq_api_key_here

# Option B — OpenRouter (many free models at openrouter.ai)
# OPEN_ROUTER_API_KEY=your_openrouter_key_here

# Option C — OpenAI
# OPENAI_API_KEY=your_openai_key_here

# ── If using Option B or C, also update config.json ─────────────────────────
# Set "client" to "open_router" or "openai" in config.json
